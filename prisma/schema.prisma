// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String?  @unique
  name        String?
  role        String   @default("resident") // Options: resident | admin
  regionCode  String?
  createdAt   DateTime @default(now())

  // Relationships
  alerts      Alert[]            @relation("UserAlerts")
  reports     IncidentReport[]
  rescueCard      RescueCard?
  emergencyPlans EmergencyPlan[]
  emergencyContactConsentRequests EmergencyContactConsentRequest[]
}

// Pillar 1: Crisis Action (Reports & Rescue)
model IncidentReport {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lat         Float
  lng         Float
  address     String?
  hazardType  String   // e.g., flood, landslide
  description String
  status      String   @default("new") // Options: new | reviewing | resolved
  aiTriage    Json?    // Stores the AI's suggested severity, tags, and actions
  createdAt   DateTime @default(now())
}

model RescueCard {
  id                    String   @id @default(uuid())
  userId                String   @unique // This makes it a One-to-One relation!
  bloodType             String?
  allergies             String?  // e.g., "Penicillin, Peanuts"
  medicalConditions     String?  // e.g., "Asthma, Type 1 Diabetes"
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactGmail String?
  homeLat               Float?   // Their safe home location
  homeLng               Float?
  homeAddress           String?
  updatedAt             DateTime @updatedAt

  shareableUrl          String?
  qrCodeData            String?  // Saves the image as a text string!

  user                  User     @relation(fields: [userId], references: [id])
}

model EmergencyContactConsentRequest {
  id                   String   @id @default(uuid())
  requesterUserId      String
  requesterUser        User     @relation(fields: [requesterUserId], references: [id])
  requesterEmail       String
  requesterName        String?
  emergencyContactName String?
  pendingEmail         String
  token                String   @unique
  status               String   @default("pending") // pending | approved | declined | replaced | expired
  expiresAt            DateTime
  approvedAt           DateTime?
  declinedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([requesterUserId, status])
}

// Pillar 2: Real-Time Monitoring (Alerts)
model Alert {
  id           String   @id @default(uuid())
  createdBy    String
  creator      User     @relation("UserAlerts", fields: [createdBy], references: [id])
  regionCode   String
  source       String   @default("third_party_api") // Options: third_party_api | user_report
  hazardType   String   // e.g., flood, landslide
  severity     String   // Options: info | watch | warning
  title        String
  body         String
  notes        String?  // Made optional just in case!
  
  // --- ADDED FOR MAP FEATURES ---
  lat          Float?   
  lng          Float?   

  status       String   @default("published") // Options: draft | published
  
  createdAt    DateTime @default(now())
}

// Pillar 3: Disaster Preparedness (E-Learning & Plans)
model EmergencyPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  hazardType  String
  checklist   Json     // Stores the AI-generated checklists
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

