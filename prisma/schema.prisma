generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @db.Uuid
  email       String?  @unique
  name        String?
  role        String   @default("resident") // resident | admin
  regionCode  String?
  createdAt   DateTime @default(now())

  alerts      Alert[]            @relation("UserAlerts")
  reports     IncidentReport[]
  rescueCard  RescueCard?
  plans       EmergencyPlan[]
  completions LessonCompletion[]
}

model IncidentReport {
  id          String   @id @default(uuid())
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  lat         Float
  lng         Float
  address     String?
  hazardType  String
  description String
  status      String   @default("new")
  aiTriage    Json?
  createdAt   DateTime @default(now())
}

model RescueCard {
  id                    String   @id @default(uuid())
  userId                String   @unique @db.Uuid
  bloodType             String?
  allergies             String?
  medicalConditions     String?
  emergencyContactName  String?
  emergencyContactPhone String?
  homeLat               Float?
  homeLng               Float?
  updatedAt             DateTime @updatedAt
  shareableUrl          String?
  qrCodeData            String?

  user                  User     @relation(fields: [userId], references: [id])
}

model Alert {
  id           String   @id @default(uuid())
  createdBy    String   @db.Uuid
  creator      User     @relation("UserAlerts", fields: [createdBy], references: [id])
  regionCode   String
  hazardType   String
  severity     String
  title        String
  body         String
  notes        String
  createdAt    DateTime @default(now())
}

model EmergencyPlan {
  id          String   @id @default(uuid())
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  hazardType  String
  planDetails Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id           String   @id @default(uuid())
  topic        String
  hazardType   String
  content      String
  quiz         Json
  createdAt    DateTime @default(now())

  completions  LessonCompletion[]
}

model LessonCompletion {
  id          String   @id @default(uuid())
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  score       Float?
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
}